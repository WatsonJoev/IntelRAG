# IntelRAG Environment Configuration
# Copy to .env and fill in values

# Environment: development | staging | production
ENVIRONMENT=development

# OpenRouter AI Gateway (required for LLM)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://intelrag.example.com
OPENROUTER_X_TITLE=IntelRAG

# Database (SQLite for dev; PostgreSQL for prod)
DATABASE_URL=sqlite:///./data/intelrag.db
# Production example: postgresql://user:password@localhost:5432/intelrag
DB_USER=
DB_PASSWORD=

# Redis (optional in dev; use fakeredis if not set)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_MEMORY=4gb

# Vector store: chromadb (dev) | qdrant (prod)
VECTOR_STORE_BACKEND=chromadb
CHROMA_PERSIST_DIR=./data/chroma
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# File store: local (dev) | minio | s3
FILE_STORE_BACKEND=local
FILE_STORE_PATH=./data/uploads
# MinIO/S3 (when FILE_STORE_BACKEND=minio or s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=intelrag-docs
# S3_ENDPOINT_URL=http://localhost:9000

# Embedding model (local)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=64

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_DOC=5000

# Retrieval
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.3
HYBRID_SEARCH=true

# Model tiers (OpenRouter model IDs)
TIER_1_MODEL=meta-llama/llama-3.2-3b-instruct:free
TIER_2_MODEL=meta-llama/llama-3.3-70b-instruct:free
TIER_3_MODEL=openai/gpt-4o-mini

# Cache TTL (seconds)
CACHE_EXACT_TTL=86400
CACHE_SEMANTIC_TTL=172800
CACHE_SEMANTIC_SIMILARITY_THRESHOLD=0.95

# Limits
MAX_FILE_SIZE_MB=200
QUERY_RATE_LIMIT_PER_USER=100

# Security — Basic Auth (both required to enable; leave blank to disable in dev)
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
# MUST be changed in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
# Cost circuit-breaker — max daily LLM spend in USD (0 = disabled)
DAILY_COST_LIMIT_USD=0.0

# Infrastructure auth (required for docker compose --profile full)
REDIS_PASSWORD=
QDRANT_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
